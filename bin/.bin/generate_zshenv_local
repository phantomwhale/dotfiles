#!/bin/zsh
#
# Generate ~/.zshenv.local from 1Password.
#
# Each entry in `items` names a 1Password **API Credential** item whose:
#   - "username" field contains space-separated ENV VAR NAMES
#   - "credential" field contains space-separated values (matching order)
#
# Lookups are scoped to the API Credential category to avoid accidentally
# matching a Login (or other-category) item with the same name.
#
# Re-run this manually whenever secrets are rotated or added.
# The output file is sourced by ~/.zshenv on every shell start.

set -euo pipefail

OUTPUT="${ZDOTDIR:-$HOME}/.zshenv.local"
TMP="$(mktemp "${TMPDIR:-/tmp}/zshenv.local.XXXXXX")"
trap 'rm -f "$TMP"' EXIT

# 1Password items to fetch. Each must exist as an API Credential whose title
# matches one of these names exactly.
items=(
  anthropic
  amp
  exa
  bugsnag
)

# Build a title -> id map of API Credentials in 1Password. One `op item list`
# call upfront; subsequent gets use the ID, which is faster than name lookups
# and is category-scoped by construction (no chance of matching a Login item).
typeset -A id_by_name
while IFS=$'\t' read -r id title; do
  id_by_name[$title]=$id
done < <(
  op item list --categories "API Credential" --format json \
    | jq -r '.[] | "\(.id)\t\(.title)"'
)

{
  echo "# Generated by ~/.bin/generate_zshenv_local on $(date -u +%Y-%m-%dT%H:%M:%SZ)"
  echo "# DO NOT EDIT - regenerate via: generate_zshenv_local"
  echo

  for search in "${items[@]}"; do
    item_id="${id_by_name[$search]:-}"
    if [[ -z "$item_id" ]]; then
      >&2 echo "skip: no API Credential item titled '$search' found in 1Password"
      continue
    fi
    keys_string=$(op item get "$item_id" --fields label=username)
    values_string=$(op item get "$item_id" --fields label=credential --reveal)

    read -A keys   <<< "$keys_string"
    read -A values <<< "$values_string"

    # If there are fewer values than keys, reuse the last value for the rest.
    # E.g. "GITHUB_TOKEN GITHUB_AUTH_TOKEN" with password "foo" sets both to "foo".
    local last_value=""
    for ((i = 1; i <= $#keys; i++)); do
      if [[ -n "${values[$i]:-}" ]]; then
        last_value="${values[$i]}"
      fi
      echo "export ${keys[$i]}=${(q)last_value}"
      >&2 echo "written ${keys[$i]}"
    done
  done
} > "$TMP"

mv "$TMP" "$OUTPUT"
trap - EXIT
>&2 echo "wrote $OUTPUT"
